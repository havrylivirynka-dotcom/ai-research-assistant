# === OpenAI ===
OPENAI_API_KEY=
# Chat/completions model used by the AI service layer (Responses API).
OPENAI_MODEL=gpt-5.1
# Embedding model used for the МАН Expert RAG knowledge base.
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# === Rate limiting (Upstash Redis) ===
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# === Scientific search providers ===
# Optional but recommended: identifies requests to OpenAlex/CrossRef's polite pool for higher rate limits.
CONTACT_EMAIL=
# Optional: raises Semantic Scholar rate limits.
SEMANTIC_SCHOLAR_API_KEY=
# Optional: raises NCBI/PubMed E-utilities rate limits.
PUBMED_API_KEY=

# === Application ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
